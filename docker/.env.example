DATASOURCE_URL=jdbc:postgresql://postgres:5432/bikerental
DATASOURCE_USER=postgres
DATASOURCE_SECRET=postgres
SERVER_PORT=80
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202

# security properties
OAUTH2_ISSUER=http://localhost:8080

# admin app
ADMIN_SPA_CLIENT_ID=bike-rental-admin
ADMIN_SPA_REDIRECT_URIS=http://localhost:4201/login/callback
ADMIN_SPA_POST_LOGOUT_URIS=http://localhost:4201

# operator app
OPERATOR_SPA_CLIENT_ID=bike-rental-operator
OPERATOR_SPA_REDIRECT_URIS=http://localhost:4202/login/callback
OPERATOR_SPA_POST_LOGOUT_URIS=http://localhost:4202

# bootstrap initial admin user
BOOTSTRAP_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@bike-rental.local
