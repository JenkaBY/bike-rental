DATASOURCE_URL=jdbc:postgresql://postgres:5432/bikerental
DATASOURCE_USER=postgres
DATASOURCE_SECRET=postgres
SPRING_LIQUIBASE_USER=postgres
SPRING_LIQUIBASE_PASSWORD=postgres

SERVER_PORT=80
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202

# security properties
OAUTH2_ISSUER=http://localhost:8080

# JWT signing keys (RS256). Leave the locations empty to auto-generate an ephemeral key on
# startup (dev convenience — tokens break on every restart). Provide a persistent RSA key pair
# to keep tokens valid across restarts and multiple instances. See docs/jwt-keys.md.
# The compose file mounts ./keys into the container at /run/secrets.
JWT_KEY_ID=bike-rental-identity
JWT_PRIVATE_KEY_LOCATION=file:/run/secrets/jwt-private.pem
JWT_PUBLIC_KEY_LOCATION=file:/run/secrets/jwt-public.pem
# During rotation, expose the retired public key(s) so previously issued tokens still verify
# (see docs/jwt-keys.md). Indexed env binding:
# APP_SECURITY_JWT_PREVIOUSKEYS_0_KEYID=bike-rental-identity-prev
# APP_SECURITY_JWT_PREVIOUSKEYS_0_PUBLICKEYLOCATION=file:/run/secrets/jwt-public-prev.pem

# admin app
ADMIN_SPA_CLIENT_ID=bike-rental-admin
ADMIN_SPA_REDIRECT_URIS=http://localhost:4200/admin/login/callback,http://localhost:4201/admin/login/callback
ADMIN_SPA_POST_LOGOUT_URIS=http://localhost:4201,http://localhost:4200/admin

# operator app
OPERATOR_SPA_CLIENT_ID=bike-rental-operator
OPERATOR_SPA_REDIRECT_URIS=http://localhost:4202/login/callback
OPERATOR_SPA_POST_LOGOUT_URIS=http://localhost:4202

# bootstrap initial admin user
BOOTSTRAP_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_EMAIL=admin@bike-rental.local
