# Copy to `.env` and fill in strong, unique values. NEVER commit `.env`.
# Generate good passwords with e.g.:  openssl rand -base64 24

# ---- PostgreSQL image -------------------------------------------------------
# Pin to an exact minor for reproducibility once you know the latest 15.x,
# e.g. postgres:15.13-alpine. Keep version parity with the app's tested version.
POSTGRES_IMAGE=postgres:15.18-alpine

# ---- Database ---------------------------------------------------------------
POSTGRES_DB=bikerental

# Additional databases to create alongside POSTGRES_DB, space-separated. Each
# gets the same four roles and privilege model, and is reachable over the
# internet for the liquibase/app/app_migrator roles (admin stays LAN-only).
# Leave empty for none. Example for a remote test database:
EXTRA_DATABASES=bikerental_test

# ---- Superuser (INTERNAL ONLY - never reachable over TCP) -------------------
POSTGRES_PASSWORD=change-me-strong-superuser-password

# ---- Role passwords (each role has distinct privileges - see README) --------
BIKERENTAL_ADMIN_PASSWORD=change-me-admin
BIKERENTAL_LIQUIBASE_PASSWORD=change-me-liquibase
BIKERENTAL_APP_PASSWORD=change-me-app
BIKERENTAL_APP_MIGRATOR_PASSWORD=change-me-app-migrator

# ---- Networking -------------------------------------------------------------
# Host port published for PostgreSQL. Point your router's forwarded external
# port at this. 5432 is fine on the Pi; the obscurity is at the router edge.
PG_PUBLISHED_PORT=5432

# Your LAN subnet in CIDR. The admin role is restricted to this range; the
# liquibase/app/app_migrator roles are reachable from the internet.
LAN_SUBNET=192.168.1.0/24

# Your router's LAN IP. The router source-NATs inbound internet connections to
# this address (which is inside LAN_SUBNET), so admin is explicitly REJECTED
# from it — otherwise the internet path could reach the admin role. Must not be
# the IP of a machine you administer the DB from.
ROUTER_IP=192.168.1.1

# ---- Storage ----------------------------------------------------------------
# Named Docker volume identifier.
PGDATA_VOLUME=bike-rental-pgdata

# Absolute path on the Pi where Postgres data is stored (on the NVMe).
# The directory must exist and be owned by uid 70 before first start:
#   sudo mkdir -p /data/postgres && sudo chown 70:70 /data/postgres
# On Windows leave this unset — Docker manages the volume location internally.
PGDATA_HOST_PATH=/data/postgres

# Host directory for SQL backups. Use an absolute path — relative paths break
# when the backup is run by the systemd timer (CWD is not the project folder).
BACKUP_DIR=/home/YOUR_USERNAME/bike-rental/docker/raspberrypi/backups
