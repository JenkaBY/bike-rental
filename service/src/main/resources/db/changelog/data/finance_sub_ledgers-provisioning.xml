<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="finance_sub_ledgers.provision-data" author="copilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="finance_sub_ledgers"/>
            <sqlCheck expectedResult="0">SELECT COUNT(*)
                                         FROM finance_sub_ledgers
                                         WHERE account_id =
                                               '00000000-0000-0000-0000-000000000001'
            </sqlCheck>
        </preConditions>

        <loadData tableName="finance_sub_ledgers"
            file="data/finance_sub_ledgers.csv"
            relativeToChangelogFile="true">
        <column name="id" type="uuid"/>
        <column name="account_id" type="uuid"/>
        <column name="ledger_type" type="string"/>
        <column name="balance" type="numeric"/>
        <column name="created_at" type="datetime"/>
        <column name="updated_at" type="datetime"/>
        <column name="version" type="numeric"/>
      </loadData>
    </changeSet>

</databaseChangeLog>
