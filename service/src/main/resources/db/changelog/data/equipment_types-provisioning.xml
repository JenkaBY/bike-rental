<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="equipment_types.provision-data" author="bikerental" context="!test">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="equipment_types"/>
        </preConditions>

        <loadData tableName="equipment_types"
                  file="data/equipment_types.csv"
                  relativeToChangelogFile="true">
            <column name="id" type="numeric"/>
            <column name="slug" type="string"/>
            <column name="name" type="string"/>
            <column name="description" type="string"/>
        </loadData>
    </changeSet>

</databaseChangeLog>
