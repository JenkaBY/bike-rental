<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="finance_transaction_records.create-index_ledger-type" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_finance_transaction_records_ledger_type"/>
            </not>
        </preConditions>

        <createIndex indexName="idx_finance_transaction_records_ledger_type"
                     tableName="finance_transaction_records">
            <column name="ledger_type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
