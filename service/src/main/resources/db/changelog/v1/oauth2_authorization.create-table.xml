<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="oauth2_authorization.create-table" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="oauth2_authorization"/>
            </not>
        </preConditions>

        <createTable tableName="oauth2_authorization">
            <column name="id" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="registered_client_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="principal_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="authorization_grant_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="authorized_scopes" type="VARCHAR(1000)"/>
            <column name="attributes" type="TEXT"/>
            <column name="state" type="VARCHAR(500)"/>
            <column name="authorization_code_value" type="TEXT"/>
            <column name="authorization_code_issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="authorization_code_expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="authorization_code_metadata" type="TEXT"/>
            <column name="access_token_value" type="TEXT"/>
            <column name="access_token_issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="access_token_expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="access_token_metadata" type="TEXT"/>
            <column name="access_token_type" type="VARCHAR(100)"/>
            <column name="access_token_scopes" type="VARCHAR(1000)"/>
            <column name="oidc_id_token_value" type="TEXT"/>
            <column name="oidc_id_token_issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="oidc_id_token_expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="oidc_id_token_metadata" type="TEXT"/>
            <column name="refresh_token_value" type="TEXT"/>
            <column name="refresh_token_issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="refresh_token_expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="refresh_token_metadata" type="TEXT"/>
            <column name="user_code_value" type="TEXT"/>
            <column name="user_code_issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="user_code_expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="user_code_metadata" type="TEXT"/>
            <column name="device_code_value" type="TEXT"/>
            <column name="device_code_issued_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="device_code_expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="device_code_metadata" type="TEXT"/>
        </createTable>

        <createIndex tableName="oauth2_authorization" indexName="idx_oauth2_authorization_principal_name">
            <column name="principal_name"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
