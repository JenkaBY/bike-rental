<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="finance_transaction_records.update-table_add-running-balance" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="finance_transaction_records" columnName="running_balance"/>
            </not>
        </preConditions>

        <addColumn tableName="finance_transaction_records">
            <column name="running_balance" type="DECIMAL(19,2)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
